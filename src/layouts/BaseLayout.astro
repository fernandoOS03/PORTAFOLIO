---
// BaseLayout.astro — Root layout for all pages
export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "Desarrollador Backend especializado en transformar requerimientos de negocio complejos en arquitecturas escalables y de alta disponibilidad.",
  ogImage = "/og-image.jpg",
} = Astro.props;

const siteUrl = "https://fernandoolivera.dev";
const fullTitle = `${title} | Fernando Olivera — Backend Developer`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="index, follow" />

    <!-- Primary SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Fernando Olivera" />
    <meta name="keywords" content="Backend Developer, Java, Node.js, Spring Boot, AWS, Docker, RabbitMQ, Portfolio" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:locale" content="es_ES" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link rel="icon" type="image/png" href="/favicon.png?v=2" />
    <link rel="shortcut icon" href="/favicon.ico?v=2" />

    <!-- Preconnect for fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Canonical -->
    <link rel="canonical" href={siteUrl} />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
