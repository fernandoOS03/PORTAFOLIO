        </svg>
      </a>
      <a href="https://www.linkedin.com/in/fernando-olivera-a77437307/" target="_blank" rel="noopener noreferrer" class="footer-social" aria-label="LinkedIn" id="link-footer-linkedin">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
      <a href="mailto:contacto@fernando.192023@outlook.es" class="footer-social" aria-label="Email" id="link-footer-email">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,13 2,6"/>
        </svg>
      </a>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border-ghost);
    padding: var(--space-6) 0;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .footer-left {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .footer-logo-link {
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .footer-logo-icon {
    flex-shrink: 0;
    transition: transform var(--t-fast) var(--ease-out);
  }

  .footer-logo-link:hover .footer-logo-icon {
    transform: scale(1.12) rotate(-6deg);
  }

  .footer-copy {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--ink-tertiary);
    letter-spacing: 0.04em;
  }

  .footer-link {
    color: var(--gold);
    transition: color var(--t-fast);
  }

  .footer-link:hover {
    color: var(--ink-primary);
  }

  .footer-right {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .footer-social {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: var(--r-sm);
    color: var(--ink-tertiary);
    border: 1px solid var(--border-ghost);
    transition: all var(--t-fast);
  }

  .footer-social:hover {
    color: var(--cyan);
    border-color: var(--border-subtle);
    background: var(--cyan-dim);
  }
</style>
