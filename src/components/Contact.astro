---
// Contact.astro — Small contact section
const serviceId = import.meta.env.EMAILJS_SERVICE_ID || 'service_9sxlq4h';
const templateId = import.meta.env.EMAILJS_TEMPLATE_ID || 'template_h5dtxwm';
const publicKey = import.meta.env.EMAILJS_PUBLIC_KEY || 'vYOn5cHdVZ6RFLZGQ';
const emailDestino = import.meta.env.EMAIL_DESTINO || 'fernando.192023@outlook.com';
---

<section class="section contact-section" id="contacto">
  <div class="container">
    <div class="section-header">
      <span class="section-label">04. contacto</span>
    </div>

    <div class="contact-grid">
      <div class="contact-left">
        <h2 class="display-md contact-title">
          ¿Quieres sumarme<br />a tu equipo?
        </h2>
        <p class="contact-desc">
          Estoy buscando una posición remota como Backend Developer en un
          equipo que valore la calidad de código, las buenas prácticas de
          arquitectura y el aprendizaje continuo.
        </p>
        <p class="contact-desc">
          Si estás contratando o quieres conocer mi perfil, escríbeme.
          Respondo en menos de 24 horas.
        </p>

        <div class="contact-socials">
          <a href="https://github.com/fernandoOS03" target="_blank" rel="noopener noreferrer" class="social-link" id="link-github-contact" aria-label="GitHub">
            <div class="social-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.929.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
              </svg>
            </div>
            <span>GitHub</span>
          </a>
          <a href="https://linkedin.com/in/fernando-olivera-a77437307" target="_blank" rel="noopener noreferrer" class="social-link" id="link-linkedin-contact" aria-label="LinkedIn">
            <div class="social-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </div>
            <span>LinkedIn</span>
          </a>
        </div>
      </div>

      <div class="contact-card">
        <div class="contact-card-header">
          <div class="contact-status">
            <span class="status-dot" aria-hidden="true"></span>
            <span class="status-text">Open to Work</span>
          </div>
        </div>

        <div class="contact-card-body">
          <p class="contact-prompt">
            <span class="t-prompt">recruiter</span><span class="t-sep"> ›</span> Contáctame
          </p>

          <a
            href="mailto:contacto@fernando.192023@outlook.es"
            class="contact-email"
            id="link-email-contact"
          >
            fernando.192023@outlook.es

          </a>

          <div class="contact-divider">
            <span>o usa el formulario</span>
          </div>

          <form
            class="contact-form"
            id="contact-form"
            data-service-id={serviceId}
            data-template-id={templateId}
            data-public-key={publicKey}
            data-email-destino={emailDestino}
            novalidate
          >
            <div class="form-field">
              <label for="contact-name" class="form-label">Nombre</label>
              <input
                type="text"
                id="contact-name"
                name="name"
                class="form-input"
                placeholder="Tu nombre"
                required
                autocomplete="name"
              />
            </div>

            <div class="form-field">
              <label for="contact-email" class="form-label">Email</label>
              <input
                type="email"
                id="contact-email"
                name="email"
                class="form-input"
                placeholder="tu@email.com"
                required
                autocomplete="email"
              />
            </div>

            <div class="form-field">
              <label for="contact-message" class="form-label">Mensaje</label>
              <textarea
                id="contact-message"
                name="message"
                class="form-input form-textarea"
                placeholder="Empresa, rol y modalidad de trabajo..."
                rows="4"
                required
              ></textarea>
            </div>

            <button type="submit" class="btn btn-primary" id="btn-contact-submit" style="width:100%; justify-content:center;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <line x1="22" y1="2" x2="11" y2="13"/>
                <polygon points="22 2 15 22 11 13 2 9 22 2"/>
              </svg>
              Enviar mensaje
            </button>

            <p class="form-success" id="form-success" aria-live="polite">
              ✓ Mensaje enviado. ¡Hablamos pronto!
            </p>

            <p class="form-error" id="form-error" aria-live="polite">
              ✗ Error al enviar. Inténtalo de nuevo o escríbeme directamente.
            </p>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: start;
  }

  .contact-left {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    animation: fadeUp 0.6s var(--ease-out) both;
  }

  .contact-title {
    color: var(--ink-primary);
  }

  .contact-desc {
    font-size: 0.9375rem;
    color: var(--ink-secondary);
    line-height: 1.7;
  }

  .contact-socials {
    display: flex;
    gap: var(--space-4);
    margin-top: var(--space-2);
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--ink-secondary);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--border-subtle);
    border-radius: var(--r-sm);
    transition: all var(--t-fast);
  }

  .social-link:hover {
    color: var(--cyan);
    border-color: var(--border-standard);
    background: var(--cyan-dim);
  }

  .social-icon {
    color: inherit;
    display: flex;
  }

  .contact-card {
    background: var(--surface-1);
    border: 1px solid var(--border-subtle);
    border-radius: var(--r-xl);
    overflow: hidden;
    animation: fadeUp 0.6s var(--ease-out) 0.15s both;
  }

  .contact-card-header {
    padding: var(--space-4) var(--space-5);
    border-bottom: 1px solid var(--border-ghost);
    background: var(--surface-2);
    display: flex;
    align-items: center;
  }

  .contact-status {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #28C840;
    animation: pulse-dot 2s ease-in-out infinite;
    box-shadow: 0 0 0 0 rgba(40, 200, 64, 0.4);
  }

  @keyframes pulse-dot {
    0%   { box-shadow: 0 0 0 0 rgba(40, 200, 64, 0.4); }
    70%  { box-shadow: 0 0 0 6px rgba(40, 200, 64, 0); }
    100% { box-shadow: 0 0 0 0 rgba(40, 200, 64, 0); }
  }

  .status-text {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: #28C840;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .contact-card-body {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .contact-prompt {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--ink-secondary);
  }
  .contact-prompt .t-prompt { color: var(--cyan); }
  .contact-prompt .t-sep    { color: var(--ink-muted); }

  .contact-email {
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--gold);
    letter-spacing: 0.02em;
    transition: color var(--t-fast);
    word-break: break-all;
  }

  .contact-email:hover {
    color: var(--ink-primary);
  }

  .contact-divider {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--ink-muted);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.06em;
  }

  .contact-divider::before,
  .contact-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border-ghost);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .form-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--ink-tertiary);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .form-input {
    background: var(--surface-2);
    border: 1px solid var(--border-subtle);
    border-radius: var(--r-sm);
    padding: var(--space-3) var(--space-4);
    color: var(--ink-primary);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    transition: border-color var(--t-fast), box-shadow var(--t-fast);
    outline: none;
    resize: none;
  }

  .form-input::placeholder {
    color: var(--ink-muted);
  }

  .form-input:focus {
    border-color: var(--border-emphasis);
    box-shadow: 0 0 0 3px var(--cyan-dim);
  }

  .form-textarea {
    min-height: 100px;
    resize: vertical;
  }

  .form-success {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--cyan);
    text-align: center;
    display: none;
    animation: fadeUp 0.4s var(--ease-out) both;
  }

  .form-success.visible {
    display: block;
  }

  .form-error {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: #ff5f57;
    text-align: center;
    display: none;
    animation: fadeUp 0.4s var(--ease-out) both;
  }

  .form-error.visible {
    display: block;
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success')!;
  const errorElement = document.getElementById('form-error')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    success.classList.remove('visible');
    errorElement.classList.remove('visible');

    // Basic client-side validation
    const nameInput = document.getElementById('contact-name') as HTMLInputElement;
    const emailInput = document.getElementById('contact-email') as HTMLInputElement;
    const messageInput = document.getElementById('contact-message') as HTMLTextAreaElement;

    if (!nameInput.value.trim() || !emailInput.value.trim() || !messageInput.value.trim()) {
      errorElement.textContent = '✗ Por favor, completa todos los campos.';
      errorElement.classList.add('visible');
      return;
    }

    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(emailInput.value.trim())) {
      errorElement.textContent = '✗ Por favor, ingresa un correo electrónico válido.';
      errorElement.classList.add('visible');
      return;
    }

    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalBtnHTML = btn.innerHTML;
    btn.textContent = 'Enviando...';
    btn.disabled = true;

    // Retrieve variables from dataset
    const serviceId = form.dataset.serviceId || 'service_9sxlq4h';
    const templateId = form.dataset.templateId || 'template_h5dtxwm';
    const publicKey = form.dataset.publicKey || 'vYOn5cHdVZ6RFLZGQ';
    const emailDestino = form.dataset.emailDestino || 'fernando.192023@outlook.com';

    try {
      const response = await fetch('https://api.emailjs.com/api/v1.0/email/send', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          service_id: serviceId,
          template_id: templateId,
          user_id: publicKey,
          template_params: {
            from_name: nameInput.value.trim(),
            from_email: emailInput.value.trim(),
            message: messageInput.value.trim(),
            name: nameInput.value.trim(),
            email: emailInput.value.trim(),
            to_email: emailDestino
          }
        })
      });

      if (response.ok) {
        form.reset();
        success.classList.add('visible');
        setTimeout(() => success.classList.remove('visible'), 6000);
      } else {
        const errorText = await response.text();
        console.error('EmailJS Error:', errorText);
        errorElement.textContent = '✗ Error al enviar. Inténtalo de nuevo o escríbeme directamente.';
        errorElement.classList.add('visible');
      }
    } catch (err) {
      console.error('Connection Error:', err);
      errorElement.textContent = '✗ Error de conexión. Revisa tu red o escríbeme por LinkedIn.';
      errorElement.classList.add('visible');
    } finally {
      btn.disabled = false;
      btn.innerHTML = originalBtnHTML;
    }
  });
</script>
